# Copy this file to `.env` in the same directory, then fill in real values:
#
#   cp ~/.pi/agent/.env.example ~/.pi/agent/.env
#   chmod 600 ~/.pi/agent/.env
#
# Loaded at session start by extensions/env.ts. Anything already exported in your
# shell wins over what's here, and a project-local <cwd>/.pi/.env wins over this file.
#
# `.env` is gitignored. Never put real keys in this .example file — it IS committed.

# Web search via Exa — https://dashboard.exa.ai/api-keys
EXA_API_KEY=

# Format notes:
#   KEY=value                 unquoted; a " #" starts a trailing comment
#   export KEY=value          the export prefix is accepted and ignored
#   KEY="with \n escapes"     double quotes interpret \n \r \t \" \\
#   KEY='literal $value'      single quotes are literal
