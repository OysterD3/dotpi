{
  "theme": "one-dark-pro",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.6-sol",
  "defaultThinkingLevel": "medium",
  "permissions": {
    "defaultMode": "askDestructive",

    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/id_rsa)",
      "Read(**/*.pem)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Write(**/.env)",
      "Edit(**/.env)"
    ],

    "ask": [],

    "allow": [
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(pnpm test *)",
      "Bash(pnpm lint *)"
    ],

    "allowDestructive": [],

    "destructiveOverridesAllow": true,
    "askWithoutUi": "deny"
  }
}
