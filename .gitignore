# Secrets — never publish
.env
*.env
!*.env.example
agent/sessions/
agent/auth.json

# /rewind checkpoints: copies of your working files, per session. Never publish.
agent/file-history/

# Per-machine settings: pi rewrites this at runtime (thinking level, model, etc.),
# so it churns and would fight `git pull`. Copy agent/settings.example.json to
# agent/settings.json on a new machine and adjust.
agent/settings.json

# self-update extension's throttle timestamp — local bookkeeping, not config
agent/.self-update.json

# Regenerated by pi on startup; version-specific, churns constantly
agent/models-store.json
agent/trust.json

# Language server binaries — reinstall with: cd agent/lsp && pnpm install
# package.json and the lockfile ARE tracked, so versions stay reproducible.
agent/lsp/node_modules/
agent/lsp/bin/

# Skills are symlinks into ~/.agents/skills (shared with other agents), not part of this config
agent/skills/

.DS_Store
